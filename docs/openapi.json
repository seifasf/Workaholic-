{
  "openapi": "3.0.3",
  "info": {
    "title": "Workaholic API",
    "version": "1.0.0",
    "description": "OpenAPI specification for the Workaholic backend (Express + MongoDB)."
  },
  "servers": [
    {
      "url": "https://workaholic-v2l5.onrender.com",
      "description": "Production (Render)"
    },
    {
      "url": "http://localhost:5000",
      "description": "Local development"
    }
  ],
  "tags": [
    { "name": "Health" },
    { "name": "Auth" },
    { "name": "Attendance" },
    { "name": "Leave" },
    { "name": "KPI" },
    { "name": "Admin" },
    { "name": "Notifications" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": { "message": { "type": "string" } },
        "required": ["message"]
      },
      "User": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "name": { "type": "string" },
          "email": { "type": "string" },
          "role": { "type": "string", "enum": ["employee", "hr", "admin"] },
          "department": { "type": "string" },
          "position": { "type": "string" },
          "avatar": { "type": "string" },
          "workStartTime": { "type": "string", "example": "09:00" },
          "vacationBalance": { "type": "number" },
          "kpiScore": { "type": "number" },
          "isActive": { "type": "boolean" },
          "createdAt": { "type": "string" },
          "updatedAt": { "type": "string" }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "user": { "$ref": "#/components/schemas/User" }
        },
        "required": ["token", "user"]
      },
      "AttendanceRecord": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "userId": { "type": "string" },
          "date": { "type": "string", "example": "2026-04-21" },
          "clockIn": { "type": "object" },
          "clockOut": { "type": "object" },
          "locationVerified": { "type": "boolean" },
          "gpsVerified": { "type": "boolean" },
          "ipVerified": { "type": "boolean" },
          "hoursWorked": { "type": "number" },
          "latenessMinutes": { "type": "number" },
          "status": { "type": "string", "enum": ["on-time", "late", "early-leave", "absent"] }
        }
      },
      "LeaveRequest": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "userId": { "type": "string" },
          "type": { "type": "string", "enum": ["vacation", "sick", "emergency", "other"] },
          "startDate": { "type": "string" },
          "endDate": { "type": "string" },
          "daysRequested": { "type": "number" },
          "reason": { "type": "string" },
          "proofUrl": { "type": "string" },
          "proofPublicId": { "type": "string" },
          "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
          "adminComment": { "type": "string" },
          "reviewedBy": { "type": "string" },
          "reviewedAt": { "type": "string" },
          "createdAt": { "type": "string" },
          "updatedAt": { "type": "string" }
        }
      },
      "KPIScore": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "userId": { "type": "string" },
          "month": { "type": "number" },
          "year": { "type": "number" },
          "punctualityScore": { "type": "number" },
          "attendanceScore": { "type": "number" },
          "leaveDeductionScore": { "type": "number" },
          "totalScore": { "type": "number" },
          "daysPresent": { "type": "number" },
          "daysAbsent": { "type": "number" },
          "totalLatenessMinutes": { "type": "number" },
          "workingDays": { "type": "number" },
          "createdAt": { "type": "string" },
          "updatedAt": { "type": "string" }
        }
      },
      "Notification": {
        "type": "object",
        "properties": {
          "_id": { "type": "string" },
          "userId": { "type": "string" },
          "message": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["leave-approved", "leave-rejected", "late-alert", "kpi-update", "general"]
          },
          "read": { "type": "boolean" },
          "link": { "type": "string" },
          "createdAt": { "type": "string" },
          "updatedAt": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/api/health": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "time": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },

    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Public registration (employee)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password"],
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" },
                  "department": { "type": "string" },
                  "position": { "type": "string" },
                  "workStartTime": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthResponse" }
              }
            }
          },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "500": { "description": "Server error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/auth/register/admin": {
      "post": {
        "tags": ["Auth"],
        "summary": "Admin/hr registration (set role)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password", "role"],
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" },
                  "role": { "type": "string", "enum": ["employee", "hr", "admin"] },
                  "department": { "type": "string" },
                  "position": { "type": "string" },
                  "workStartTime": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "403": { "description": "Forbidden", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "500": { "description": "Server error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": { "email": { "type": "string" }, "password": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AuthResponse" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "500": { "description": "Server error", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get current user",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/auth/profile": {
      "patch": {
        "tags": ["Auth"],
        "summary": "Update profile",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "department": { "type": "string" },
                  "position": { "type": "string" },
                  "workStartTime": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },

    "/api/attendance/clock-in": {
      "post": {
        "tags": ["Attendance"],
        "summary": "Clock in",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" } } }
            }
          }
        },
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/attendance/clock-out": {
      "post": {
        "tags": ["Attendance"],
        "summary": "Clock out",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" } } }
            }
          }
        },
        "responses": {
          "200": { "description": "OK" },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/attendance/history": {
      "get": {
        "tags": ["Attendance"],
        "summary": "Get my attendance history",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": { "description": "OK" },
          "401": { "description": "Unauthorized", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/attendance/today": {
      "get": {
        "tags": ["Attendance"],
        "summary": "Get today's attendance record",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" }, "401": { "description": "Unauthorized" } }
      }
    },
    "/api/attendance/my-stats": {
      "get": {
        "tags": ["Attendance"],
        "summary": "Get my monthly stats",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" }, "401": { "description": "Unauthorized" } }
      }
    },
    "/api/attendance/live": {
      "get": {
        "tags": ["Attendance"],
        "summary": "Live board (admin/hr)",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" }, "401": { "description": "Unauthorized" }, "403": { "description": "Forbidden" } }
      }
    },
    "/api/attendance/admin": {
      "get": {
        "tags": ["Attendance"],
        "summary": "Admin attendance history (admin/hr)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "userId", "in": "query", "schema": { "type": "string" } },
          { "name": "startDate", "in": "query", "schema": { "type": "string" } },
          { "name": "endDate", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" }, "401": { "description": "Unauthorized" }, "403": { "description": "Forbidden" } }
      }
    },

    "/api/leave/request": {
      "post": {
        "tags": ["Leave"],
        "summary": "Create leave request (multipart/form-data)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["type", "startDate", "endDate"],
                "properties": {
                  "type": { "type": "string", "enum": ["vacation", "sick", "emergency", "other"] },
                  "startDate": { "type": "string" },
                  "endDate": { "type": "string" },
                  "reason": { "type": "string" },
                  "proof": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Created", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/LeaveRequest" } } } },
          "400": { "description": "Bad request", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
        }
      }
    },
    "/api/leave/my-leaves": {
      "get": {
        "tags": ["Leave"],
        "summary": "Get my leave requests",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" }, "401": { "description": "Unauthorized" } }
      }
    },
    "/api/leave/balance": {
      "get": {
        "tags": ["Leave"],
        "summary": "Get my vacation balance",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" }, "401": { "description": "Unauthorized" } }
      }
    },
    "/api/leave/all": {
      "get": {
        "tags": ["Leave"],
        "summary": "Get all leave requests (admin/hr)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "status", "in": "query", "schema": { "type": "string" } },
          { "name": "userId", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" }, "401": { "description": "Unauthorized" }, "403": { "description": "Forbidden" } }
      }
    },
    "/api/leave/{id}/approve": {
      "patch": {
        "tags": ["Leave"],
        "summary": "Approve leave (admin/hr)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "type": "object", "properties": { "adminComment": { "type": "string" } } } }
          }
        },
        "responses": { "200": { "description": "OK" }, "400": { "description": "Bad request" }, "404": { "description": "Not found" } }
      }
    },
    "/api/leave/{id}/reject": {
      "patch": {
        "tags": ["Leave"],
        "summary": "Reject leave (admin/hr)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "content": {
            "application/json": { "schema": { "type": "object", "properties": { "adminComment": { "type": "string" } } } }
          }
        },
        "responses": { "200": { "description": "OK" }, "400": { "description": "Bad request" }, "404": { "description": "Not found" } }
      }
    },

    "/api/kpi/my-score": {
      "get": {
        "tags": ["KPI"],
        "summary": "Get my KPI score",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "month", "in": "query", "schema": { "type": "integer" } },
          { "name": "year", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/KPIScore" } } } } }
      }
    },
    "/api/kpi/team": {
      "get": {
        "tags": ["KPI"],
        "summary": "Get team KPI scores (admin/hr)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "month", "in": "query", "schema": { "type": "integer" } },
          { "name": "year", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": { "200": { "description": "OK" }, "403": { "description": "Forbidden" } }
      }
    },
    "/api/kpi/report/{userId}": {
      "get": {
        "tags": ["KPI"],
        "summary": "Get KPI report for user (admin/hr)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "userId", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "OK" }, "403": { "description": "Forbidden" } }
      }
    },
    "/api/kpi/compute": {
      "post": {
        "tags": ["KPI"],
        "summary": "Compute KPIs (admin only)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "type": "object", "properties": { "month": { "type": "integer" }, "year": { "type": "integer" } } }
            }
          }
        },
        "responses": { "200": { "description": "OK" }, "403": { "description": "Forbidden" } }
      }
    },

    "/api/admin/dashboard": {
      "get": {
        "tags": ["Admin"],
        "summary": "Admin dashboard (admin/hr)",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" }, "403": { "description": "Forbidden" } }
      }
    },
    "/api/admin/users": {
      "get": {
        "tags": ["Admin"],
        "summary": "List users (admin/hr)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          { "name": "role", "in": "query", "schema": { "type": "string" } },
          { "name": "department", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" }, "403": { "description": "Forbidden" } }
      },
      "post": {
        "tags": ["Admin"],
        "summary": "Create user (admin only)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "email", "password", "role"],
                "properties": {
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "password": { "type": "string" },
                  "role": { "type": "string", "enum": ["employee", "hr", "admin"] },
                  "department": { "type": "string" },
                  "position": { "type": "string" },
                  "workStartTime": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Created" }, "400": { "description": "Bad request" }, "403": { "description": "Forbidden" } }
      }
    },
    "/api/admin/users/{id}": {
      "patch": {
        "tags": ["Admin"],
        "summary": "Update user (admin only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "role": { "type": "string", "enum": ["employee", "hr", "admin"] },
                  "department": { "type": "string" },
                  "position": { "type": "string" },
                  "workStartTime": { "type": "string" },
                  "vacationBalance": { "type": "number" },
                  "isActive": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "OK" }, "404": { "description": "Not found" }, "403": { "description": "Forbidden" } }
      },
      "delete": {
        "tags": ["Admin"],
        "summary": "Deactivate user (admin only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "OK" }, "403": { "description": "Forbidden" } }
      }
    },

    "/api/notifications": {
      "get": {
        "tags": ["Notifications"],
        "summary": "Get my notifications",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Notification" } } } } } }
      }
    },
    "/api/notifications/unread-count": {
      "get": {
        "tags": ["Notifications"],
        "summary": "Get unread notifications count",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/notifications/mark-read": {
      "patch": {
        "tags": ["Notifications"],
        "summary": "Mark all notifications as read",
        "security": [{ "bearerAuth": [] }],
        "responses": { "200": { "description": "OK" } }
      }
    }
  }
}


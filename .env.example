# Copy to .env locally — never commit real secrets.

MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/database1?retryWrites=true&w=majority
JWT_SECRET=
JWT_REFRESH_SECRET=
CLIENT_URL=http://localhost:5173

# Brevo SMTP (optional — required for leave/late emails)
# Brevo Dashboard → Settings → SMTP & API
EMAIL_SMTP_USER=
EMAIL_PASS=
# Brevo → Senders — must be verified
EMAIL_FROM=
# Optional overrides (defaults match Brevo)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587

# Geo attendance (optional)
# OFFICE_LAT=
# OFFICE_LNG=
# OFFICE_RADIUS_KM=2
